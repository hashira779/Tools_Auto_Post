# ============================================
# AUTO POST — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# --- Gemini AI (for smart title/description generation) ---
GEMINI_API_KEY=your_gemini_api_key_here

# --- YouTube OAuth 2.0 ---
YOUTUBE_CLIENT_SECRETS_PATH=client_secrets.json
YOUTUBE_TOKEN_PATH=token.json

# --- TikTok API (Optional — for auto-uploading to TikTok) ---
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here

# --- Download Settings ---
DOWNLOAD_DIR=./downloads

# --- Lyric SRT Generation ---
# Temporary per-chat work directory for /srt jobs
SRT_WORK_DIR=./downloads/srt
# Reject audio longer than this many seconds (900 = 15 minutes)
SRT_MAX_AUDIO_SECONDS=900
# Whisper model: tiny, base, small, medium, large
SRT_WHISPER_MODEL=base
# Khmer language code. Leave empty for auto-detect.
SRT_WHISPER_LANGUAGE=km
# Number of concurrent /srt jobs. Whisper is CPU/GPU heavy, so 1 is safest.
SRT_MAX_CONCURRENT_TASKS=1
# Max MP4 size to send through Telegram
SRT_MAX_TELEGRAM_FILE_MB=45
# If Whisper starts very late, shift detected lyric timings to this start time.
SRT_FALLBACK_START_SECONDS=10
# Treat Whisper's first segment as late when it starts after this many seconds.
SRT_LATE_WHISPER_START_SECONDS=30
# Separate vocals from background music before alignment (true/false).
# Uses Demucs. Slower but much more accurate for songs with heavy instrumentation.
SRT_VOCAL_SEPARATION=true
# Demucs model for vocal separation (htdemucs is recommended)
SRT_DEMUCS_MODEL=htdemucs

# --- YouTube Upload Settings ---
# Initial privacy: private (recommended for copyright check)
DEFAULT_PRIVACY=private
# Auto-publish to public after copyright check passes (true/false)
AUTO_PUBLISH=true
# Seconds to wait for YouTube copyright checks (default: 300 = 5 min)
COPYRIGHT_CHECK_TIMEOUT=300
# YouTube video category ID (22 = People & Blogs)
YOUTUBE_CATEGORY_ID=22

# --- Access Control ---
# Comma-separated Telegram user IDs allowed to use the bot
# Leave empty to allow all users
ALLOWED_USERS=

# --- Logging ---
# DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
